#!/bin/bash
#SBATCH -J 40p-sasa              # job name
#SBATCH -e myjob.%j.err          # error file name 
#SBATCH -o myjob.%j.out          # output file name 
#SBATCH -N 1                     # request 1 node
#SBATCH -n 56                    # request 56 MPI tasks 
#SBATCH -p small           # designate queue 
#SBATCH -t 48:00:00               # designate max run time 
module load gromacs/2022.1
export OMP_NUM_THREADS=1         # 1 OMP thread per MPI task

# Print some debug information
echo "Starting SASA calculation"
echo "Using GROMACS version:"
gmx_mpi -version
echo "Contents of current directory:"
ls -l
echo "SLURM_NODELIST: $SLURM_NODELIST"
echo "SLURM_JOB_NUM_NODES: $SLURM_JOB_NUM_NODES"
echo "SLURM_NTASKS: $SLURM_NTASKS"
echo "SLURM_CPUS_PER_TASK: $SLURM_CPUS_PER_TASK"

# Change to the specified directory
cd /scratch1/09505/ehsan23/Planar/40/charmm-gui-9790618291/gromacs

# Check the presence of necessary files
if [[ ! -f step7_production.tpr ]]; then
    echo "Error: step7_production.tpr file not found!"
    exit 1
fi
if [[ ! -f concatenated-7us-skipped-10.xtc ]]; then
    echo "Error: concatenated-7us-skipped-10.xtc file not found!"
    exit 1
fi
if [[ ! -f index.ndx ]]; then
    echo "Error: index.ndx file not found!"
    exit 1
fi

# Calculate SASA for the entire system (group 0)
echo 0 | gmx_mpi sasa -s step7_production.tpr -f concatenated-7us-skipped-10.xtc -n index.ndx -o sasa_membe.xvg
if [[ $? -ne 0 ]]; then
    echo "Error: SASA calculation for group 0 failed!"
    exit 1
fi

# Calculate SASA for cholesterol (group 2)
echo 2 | gmx_mpi sasa -s step7_production.tpr -f concatenated-7us-skipped-10.xtc -n index.ndx -o sasa_chol.xvg
if [[ $? -ne 0 ]]; then
    echo "Error: SASA calculation for group 2 failed!"
    exit 1
fi

# Calculate SASA for DOPC (group 3)
echo 3 | gmx_mpi sasa -s step7_production.tpr -f concatenated-7us-skipped-10.xtc -n index.ndx -o sasa_dopc.xvg
if [[ $? -ne 0 ]]; then
    echo "Error: SASA calculation for group 3 failed!"
    exit 1
fi

echo "SASA calculations completed successfully!"

